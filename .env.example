# Required — your model provider key
ANTHROPIC_API_KEY=sk-ant-...

# Required — bearer token clients must send to /api routes
PONCHO_AUTH_TOKEN=change-me

# Provided automatically by the Railway Postgres service.
# For local dev, point this at your own Postgres instance.
DATABASE_URL=postgresql://user:pass@localhost:5432/poncho

# Optional — Telegram messaging.
# 1. Create a bot via @BotFather on Telegram, copy the token here.
# 2. Pick any random string for TELEGRAM_WEBHOOK_SECRET.
# 3. After deploying, register the webhook:
#    curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook" \
#      --data-urlencode "url=https://<your-railway-url>/api/messaging/telegram" \
#      --data-urlencode "secret_token=$TELEGRAM_WEBHOOK_SECRET"
# 4. Add your Telegram user ID (find via @userinfobot) to allowedUserIds in
#    poncho.config.js.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
